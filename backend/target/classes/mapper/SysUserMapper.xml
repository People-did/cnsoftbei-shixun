<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.training.mapper.SysUserMapper">
    
    <select id="selectByClassId" resultType="com.training.entity.SysUser">
        SELECT * FROM sys_user WHERE class_id = #{classId} AND role = 3
    </select>
    
    <select id="selectTeachers" resultType="com.training.entity.SysUser">
        SELECT * FROM sys_user WHERE role = 2
    </select>
    
</mapper>
